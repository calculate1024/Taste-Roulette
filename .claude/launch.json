{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server (Express)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/tsx/dist/cli.mjs", "watch", "src/index.ts"],
      "port": 3000,
      "autoPort": false,
      "cwd": "apps/api"
    },
    {
      "name": "Mobile (Expo)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/expo/bin/cli", "start"],
      "port": 8081,
      "cwd": "apps/mobile"
    },
    {
      "name": "Recommender (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "cwd": "apps/recommender"
    },
    {
      "name": "Paperclip Dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('./api/index.js');const s=require('http').createServer(async(q,r)=>{await h(q,r)});s.listen(3200,()=>console.log('Dashboard on http://localhost:3200'))"],
      "port": 3200,
      "cwd": "paperclip/dashboard"
    }
  ]
}
