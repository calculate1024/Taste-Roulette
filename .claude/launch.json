{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server (Express)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/tsx/dist/cli.mjs", "watch", "src/index.ts"],
      "port": 3000,
      "autoPort": false,
      "cwd": "apps/api"
    },
    {
      "name": "Mobile (Expo)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/expo/bin/cli", "start"],
      "port": 8081,
      "cwd": "apps/mobile"
    },
    {
      "name": "Recommender (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "cwd": "apps/recommender"
    }
  ]
}
