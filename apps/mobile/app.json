{
  "expo": {
    "name": "Taste Roulette",
    "slug": "taste-roulette",
    "scheme": "taste-roulette",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6C5CE7"
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "taste-roulette",
          "project": "taste-roulette-mobile",
          "enableAutoUploadSourceMaps": false
        }
      ],
      "expo-font",
      "expo-localization"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tasteroulette.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.tasteroulette.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e52ddfed-75db-418a-aad1-b9d8d365f29f"
      }
    },
    "owner": "calculate1024"
  }
}
